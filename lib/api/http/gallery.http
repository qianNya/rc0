# gallery-api ACGN 图库（service/gallery/api → gallery.rpc）
# 路径：/api/gallery · 权限：登录即可（不要求 gallery:manage 菜单）
# 归属：admin 全量；普通用户仅本人数据（子表以 acgn_image.creator 为准）
#   - 越权他人资源 → 403（msg: 越权访问）；无 JWT → Gateway 401
# 越权测试：用 @demoUsername 登录后访问 admin 创建的 id，应 403
@gateway = http://192.168.110.167:8888
@adminUsername = admin
@adminPassword = admin123
@demoUsername = demo_user
@demoPassword = demo_pass_123
@workId = 1
@imageId = 1
@tagId = 1
@imageFileId = 1
@imageAnalysisId = 1
@imageTagId = 1
@imageWorkId = 1



### @name adminLogin
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("accessToken", response.body.data.access_token);
%}

### @name demoLogin
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{demoUsername}}",
  "password": "{{demoPassword}}"
}

> {%
  client.global.set("demoAccessToken", response.body.data.access_token);
%}

## ── 作品 acgn_work ─────────────────────────────────────────────

### @name listWorks
GET {{gateway}}/api/gallery/works?page=1&page_size=20
Accept: application/json
Authorization: Bearer {{accessToken}}

### @name createWork
POST {{gateway}}/api/gallery/works
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "测试作品",
  "work_type": 1,
  "external_src": "manual",
  "external_id": "http-test-work-001"
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("workId", response.body.data.id);
  }
%}

### @name getWork
GET {{gateway}}/api/gallery/works/{{workId}}
Authorization: Bearer {{accessToken}}

### @name updateWork
PUT {{gateway}}/api/gallery/works/{{workId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "测试作品（已更新）"
}

# ── 图片 acgn_image ────────────────────────────────────────────

### @name listImages
GET {{gateway}}/api/gallery/images?page=1&page_size=20&image_type=1
Authorization: Bearer {{accessToken}}

### @name createImage
POST {{gateway}}/api/gallery/images
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "测试插画",
  "image_type": 1,
  "visibility": 1,
  "source_site": "manual",
  "source_post_id": "http-test-img-001"
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("imageId", response.body.data.id);
  }
%}

### @name uploadImage
POST {{gateway}}/api/gallery/images/upload
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="sample.jpg"
Content-Type: image/jpeg

< ../data/sample.jpg
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="title"

测试上传插画
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="image_type"

1
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="visibility"

3
------WebKitFormBoundary7MA4YWxkTrZu0gW--

> {%
  if (response.body.data && response.body.data.image && response.body.data.image.id) {
    client.global.set("imageId", response.body.data.image.id);
  }
  if (response.body.data && response.body.data.file && response.body.data.file.id) {
    client.global.set("imageFileId", response.body.data.file.id);
  }
%}

### @name getImage
GET {{gateway}}/api/gallery/images/{{imageId}}
Authorization: Bearer {{accessToken}}

### @name updateImage
PUT {{gateway}}/api/gallery/images/{{imageId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "测试插画（已更新）",
  "visibility": 1
}

# ── 标签 acgn_tag ──────────────────────────────────────────────

### @name listTags
GET {{gateway}}/api/gallery/tags?namespace=metaphor&page=1&page_size=20
Authorization: Bearer {{accessToken}}

### @name createTag
POST {{gateway}}/api/gallery/tags
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "namespace": "metaphor",
  "name": "上升",
  "slug": "up-http-test"
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("tagId", response.body.data.id);
  }
%}

### @name getTag
GET {{gateway}}/api/gallery/tags/{{tagId}}
Authorization: Bearer {{accessToken}}

### @name updateTag
PUT {{gateway}}/api/gallery/tags/{{tagId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "上升（已更新）"
}

# ── 图片文件 acgn_image_file ─────────────────────────────────

### @name listImageFiles
GET {{gateway}}/api/gallery/image-files?image_id={{imageId}}&page=1
Authorization: Bearer {{accessToken}}

### @name createImageFile
POST {{gateway}}/api/gallery/image-files
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "image_id": {{imageId}},
  "file_role": 1,
  "storage": "local",
  "url": "https://example.com/demo.jpg",
  "mime": "image/jpeg",
  "width": 1920,
  "height": 1080
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("imageFileId", response.body.data.id);
  }
%}

### @name getImageFile
GET {{gateway}}/api/gallery/image-files/{{imageFileId}}
Authorization: Bearer {{accessToken}}

### @name updateImageFile
PUT {{gateway}}/api/gallery/image-files/{{imageFileId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "url": "https://example.com/demo-updated.jpg"
}

# ── 分析任务 acgn_image_analysis ─────────────────────────────

### @name listImageAnalyses
GET {{gateway}}/api/gallery/image-analyses?image_id={{imageId}}&page=1
Authorization: Bearer {{accessToken}}

### @name createImageAnalysis
POST {{gateway}}/api/gallery/image-analyses
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "image_id": {{imageId}},
  "pipeline_ver": "mvp-1",
  "analyzer": "arnheim",
  "status": 2
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("imageAnalysisId", response.body.data.id);
  }
%}

### @name getImageAnalysis
GET {{gateway}}/api/gallery/image-analyses/{{imageAnalysisId}}
Authorization: Bearer {{accessToken}}

### @name updateImageAnalysis
PUT {{gateway}}/api/gallery/image-analyses/{{imageAnalysisId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "status": 3,
  "duration_ms": 1200
}

# ── 知觉指标 acgn_image_metrics（主键 image_id）────────────────

### @name listImageMetrics
GET {{gateway}}/api/gallery/image-metrics?page=1&page_size=20
Authorization: Bearer {{accessToken}}

### @name createImageMetrics
POST {{gateway}}/api/gallery/image-metrics
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "image_id": {{imageId}},
  "analysis_id": {{imageAnalysisId}},
  "balance_score": 0.72,
  "warm_cool_index": 0.15,
  "schema_up_down": 0.8
}

### @name getImageMetrics
GET {{gateway}}/api/gallery/image-metrics/{{imageId}}
Authorization: Bearer {{accessToken}}

### @name updateImageMetrics
PUT {{gateway}}/api/gallery/image-metrics/{{imageId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "balance_score": 0.85,
  "schema_balance": 0.6
}

# ── 图片-标签 acgn_image_tag ───────────────────────────────────

### @name listImageTags
GET {{gateway}}/api/gallery/image-tags?image_id={{imageId}}&page=1
Authorization: Bearer {{accessToken}}

### @name createImageTag
POST {{gateway}}/api/gallery/image-tags
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "image_id": {{imageId}},
  "tag_id": {{tagId}},
  "source": 1,
  "confidence": 1.0
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("imageTagId", response.body.data.id);
  }
%}

### @name getImageTag
GET {{gateway}}/api/gallery/image-tags/{{imageTagId}}
Authorization: Bearer {{accessToken}}

### @name updateImageTag
PUT {{gateway}}/api/gallery/image-tags/{{imageTagId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "confidence": 0.95
}

# ── 图片-作品 acgn_image_work ──────────────────────────────────

### @name listImageWorks
GET {{gateway}}/api/gallery/image-works?image_id={{imageId}}&page=1
Authorization: Bearer {{accessToken}}

### @name createImageWork
POST {{gateway}}/api/gallery/image-works
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "image_id": {{imageId}},
  "work_id": {{workId}},
  "relation_type": 1
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("imageWorkId", response.body.data.id);
  }
%}

### @name getImageWork
GET {{gateway}}/api/gallery/image-works/{{imageWorkId}}
Authorization: Bearer {{accessToken}}

### @name updateImageWork
PUT {{gateway}}/api/gallery/image-works/{{imageWorkId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "relation_type": 2
}

# ── 清理（按依赖逆序删除）────────────────────────────────────

### @name deleteImageMetrics
DELETE {{gateway}}/api/gallery/image-metrics/{{imageId}}
Authorization: Bearer {{accessToken}}

### @name deleteImageTag
DELETE {{gateway}}/api/gallery/image-tags/{{imageTagId}}
Authorization: Bearer {{accessToken}}

### @name deleteImageWork
DELETE {{gateway}}/api/gallery/image-works/{{imageWorkId}}
Authorization: Bearer {{accessToken}}

### @name deleteImageAnalysis
DELETE {{gateway}}/api/gallery/image-analyses/{{imageAnalysisId}}
Authorization: Bearer {{accessToken}}

### @name deleteImageFile
DELETE {{gateway}}/api/gallery/image-files/{{imageFileId}}
Authorization: Bearer {{accessToken}}

### @name deleteImage
DELETE {{gateway}}/api/gallery/images/{{imageId}}
Authorization: Bearer {{accessToken}}

### @name deleteTag
DELETE {{gateway}}/api/gallery/tags/{{tagId}}
Authorization: Bearer {{accessToken}}

### @name deleteWork
DELETE {{gateway}}/api/gallery/works/{{workId}}
Authorization: Bearer {{accessToken}}
