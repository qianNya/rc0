# data-api（MinIO 对象存储 BFF）
# 公开：GET /ping；需 JWT：上传、预签名下载、对象查询与删除
@gateway = http://192.168.110.167:8888/
@adminUsername = admin
@adminPassword = admin123

### @name login
# @no-redirect
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("accessToken", response.body.data.access_token);
%}

### @name ping
GET {{gateway}}/api/data/ping

### @name upload
POST {{gateway}}/api/data/upload
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="sample.jpg"
Content-Type: image/jpeg

< ./sample.jpg
------WebKitFormBoundary7MA4YWxkTrZu0gW--

> {%
  client.global.set("objectKey", response.body.data.object_key);
  client.global.set("bucket", response.body.data.bucket);
  client.global.set("md5", response.body.data.md5);
%}

### @name statObject
GET {{gateway}}/api/data/objects/stat?bucket={{bucket}}&object_key={{objectKey}}
Authorization: Bearer {{accessToken}}

### @name presignDownload
POST {{gateway}}/api/data/presign/download
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "bucket": "{{bucket}}",
  "object_key": "{{objectKey}}",
  "expire_sec": 3600
}

### @name deleteObject
DELETE {{gateway}}/api/data/objects
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "bucket": "{{bucket}}",
  "object_key": "{{objectKey}}"
}
