# screenplay-api 剧本（service/screenplay/api → screenplay.rpc）
# 路径：/api/screenplay · 权限：登录即可
@gateway = http://192.168.110.167:8888/
@adminUsername = admin
@adminPassword = admin123
@screenplayId = 21


### BEGIN GENERATED

### @name login
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("accessToken", response.body.data.access_token);
%}

### @name ping
GET {{gateway}}/api/screenplay/ping
Accept: application/json

