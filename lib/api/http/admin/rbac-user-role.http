# admin-api 用户角色（rbac.api → user.rpc/Rbac）
# 接口：POST/GET/PUT/DELETE /api/admin/user-roles[/:id]
@gateway = http://127.0.0.1:8888
@adminUsername = admin
@adminPassword = admin123
@userId = 1
@roleId = 1
@userRoleId = 1


### BEGIN GENERATED

### @name login
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("accessToken", response.body.data.access_token);
%}

### @name createUserRole
POST {{gateway}}/api/admin/user-roles
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "user_id": 1,
  "role_id": 1
}
### @name listUserRoles
GET {{gateway}}/api/admin/user-roles?page=1&page_size=20&user_id=1&role_id=1&status=1&deleted=1
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name getUserRole
GET {{gateway}}/api/admin/user-roles/{{id}}
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name updateUserRole
PUT {{gateway}}/api/admin/user-roles/{{id}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "status": 1
}
### @name deleteUserRole
DELETE {{gateway}}/api/admin/user-roles/{{id}}
Authorization: Bearer {{accessToken}}
Accept: application/json

### END GENERATED



