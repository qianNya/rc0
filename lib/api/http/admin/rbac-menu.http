# admin-api 菜单（rbac.api → user.rpc/Rbac）
# 接口：POST/GET/PUT/DELETE /api/admin/menus[/:id]
@gateway = http://127.0.0.1:8888
@adminUsername = admin
@adminPassword = admin123
@menuId = 1


### BEGIN GENERATED

### @name login
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("accessToken", response.body.data.access_token);
%}

### @name createMenu
POST {{gateway}}/api/admin/menus
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "示例名称"
}
### @name listMenus
GET {{gateway}}/api/admin/menus?page=1&page_size=20&parent_id=1&status=1&deleted=1
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name getMenu
GET {{gateway}}/api/admin/menus/{{id}}
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name updateMenu
PUT {{gateway}}/api/admin/menus/{{id}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "parent_id": 1,
  "name": "示例名称",
  "path": "example",
  "component": "example"
}
### @name deleteMenu
DELETE {{gateway}}/api/admin/menus/{{id}}
Authorization: Bearer {{accessToken}}
Accept: application/json

### END GENERATED



