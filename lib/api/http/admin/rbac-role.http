# admin-api 角色（rbac.api → user.rpc/Rbac）
# 接口：POST/GET/PUT/DELETE /api/admin/roles[/:id]
@gateway = http://127.0.0.1:8888
@adminUsername = admin
@adminPassword = admin123
@roleId = 1


### BEGIN GENERATED

### @name login
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("accessToken", response.body.data.access_token);
%}

### @name createRole
POST {{gateway}}/api/admin/roles
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "示例名称",
  "code": "example"
}
### @name listRoles
GET {{gateway}}/api/admin/roles?page=1&page_size=20&status=1&deleted=1
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name getRole
GET {{gateway}}/api/admin/roles/{{id}}
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name updateRole
PUT {{gateway}}/api/admin/roles/{{id}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "示例名称",
  "code": "example",
  "sort": 1,
  "remark": "example"
}
### @name deleteRole
DELETE {{gateway}}/api/admin/roles/{{id}}
Authorization: Bearer {{accessToken}}
Accept: application/json

