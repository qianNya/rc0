# admin-api 用户管理（user.api → user.rpc/Identity）
# 接口：POST/GET/PUT/DELETE /api/admin/users[/:id]
@gateway = http://192.168.110.167:8888
@adminUsername = admin
@adminPassword = admin123
@userId = 1


### BEGIN GENERATED

### @name login
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("accessToken", response.body.data.access_token);
%}

### @name createUmsUser
POST {{gateway}}/api/admin/users
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}
### @name listUmsUsers
GET {{gateway}}/api/admin/users?page=1&page_size=20&status=1&deleted=1
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name getUmsUser
GET {{gateway}}/api/admin/users/{{id}}
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name updateUmsUser
PUT {{gateway}}/api/admin/users/{{id}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}",
  "nickname": "示例用户",
  "email": "user@example.com"
}
### @name deleteUmsUser
DELETE {{gateway}}/api/admin/users/{{id}}
Authorization: Bearer {{accessToken}}
Accept: application/json

### END GENERATED




