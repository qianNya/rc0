# admin-api 角色菜单（rbac.api → user.rpc/Rbac）
# 接口：POST/GET/PUT/DELETE /api/admin/role-menus[/:id]
@gateway = http://127.0.0.1:8888
@adminUsername = admin
@adminPassword = admin123
@roleId = 1
@menuId = 1
@roleMenuId = 1


### BEGIN GENERATED

### @name login
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("accessToken", response.body.data.access_token);
%}

### @name createRoleMenu
POST {{gateway}}/api/admin/role-menus
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "role_id": 1,
  "menu_id": 1
}
### @name listRoleMenus
GET {{gateway}}/api/admin/role-menus?page=1&page_size=20&role_id=1&menu_id=1&status=1&deleted=1
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name getRoleMenu
GET {{gateway}}/api/admin/role-menus/{{id}}
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name updateRoleMenu
PUT {{gateway}}/api/admin/role-menus/{{id}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "status": 1
}
### @name deleteRoleMenu
DELETE {{gateway}}/api/admin/role-menus/{{id}}
Authorization: Bearer {{accessToken}}
Accept: application/json

### END GENERATED



