# reply-api 剧本评论（service/reply/api → reply.rpc）
# 路径：/api/reply · 权限：登录即可
@gateway = http://192.168.110.167:8888
@adminUsername = admin
@adminPassword = admin123

### @name login
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("accessToken", response.body.data.access_token);
%}

### @name ping
GET {{gateway}}/api/reply/ping
Accept: application/json

### @name createComment
POST {{gateway}}/api/reply/screenplays/{{screenplayId}}/comments
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "content": "很棒的分镜！"
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("commentId", response.body.data.id);
  }
%}

### @name listComments
GET {{gateway}}/api/reply/screenplays/{{screenplayId}}/comments?page=1&page_size=20
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name updateComment
PUT {{gateway}}/api/reply/comments/{{commentId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "content": "更新后的评论"
}

### @name deleteComment
DELETE {{gateway}}/api/reply/comments/{{commentId}}
Authorization: Bearer {{accessToken}}
