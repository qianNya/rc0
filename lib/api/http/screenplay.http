# screenplay-api 剧本（service/screenplay/api → screenplay.rpc）
# 路径：/api/screenplay · 权限：登录即可
@gateway = http://192.168.110.167:8888
@adminUsername = admin
@adminPassword = admin123

### @name login
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("accessToken", response.body.data.access_token);
%}

### @name ping
GET {{gateway}}/api/screenplay/ping
Accept: application/json

### @name createScreenplay
POST {{gateway}}/api/screenplay/screenplays
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "666",
  "kind": 1,
  "summary": "2333"
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("screenplayId", response.body.data.id);
  }
%}

### @name listScreenplays
GET {{gateway}}/api/screenplay/screenplays?page=1&page_size=20
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name getScreenplay
GET {{gateway}}/api/screenplay/screenplays/{{screenplayId}}
Authorization: Bearer {{accessToken}}
Accept: application/json

### @name createAct
POST {{gateway}}/api/screenplay/screenplays/{{screenplayId}}/acts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "第一幕",
  "sort": 1
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("actId", response.body.data.id);
  }
%}

### @name createScene
POST {{gateway}}/api/screenplay/screenplays/{{screenplayId}}/acts/{{actId}}/scenes
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "第一场",
  "location": "教室",
  "sort": 1
}

> {%
  if (response.body.data && response.body.data.id) {
    client.global.set("sceneId", response.body.data.id);
  }
%}

### @name createFrame
POST {{gateway}}/api/screenplay/screenplays/{{screenplayId}}/acts/{{actId}}/scenes/{{sceneId}}/frames
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "画格1",
  "dialogue": "你好",
  "sort": 1
}

### @name getTree
GET {{gateway}}/api/screenplay/screenplays/{{screenplayId}}/tree
Authorization: Bearer {{accessToken}}
Accept: application/json
